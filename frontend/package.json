{
  "name": "sched-gg-frontend",
  "version": "1.0.0",
  "description": "Schedule image builder for fighting game / Smash tournaments",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --minify --jsx=automatic --outfile=bundle.js",
    "dev": "esbuild src/index.tsx --bundle --jsx=automatic --servedir=. --outfile=bundle.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2"
  }
}
